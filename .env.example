# ════════════════════════════════════════════════════════════
#  threatintel-platform — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ════════════════════════════════════════════════════════════

# ── Tor ──────────────────────────────────────────────────────
TOR_SOCKS_HOST=tor
TOR_SOCKS_PORT=9050
TOR_CONTROL_PORT=9051
# Auto-generated by deploy.sh; to generate manually:
#   docker run --rm debian:bookworm-slim sh -c "apt-get install -y tor && tor --hash-password yourpassword"
TOR_CONTROL_PASSWORD=changeme

# ── Crawling ─────────────────────────────────────────────────
MAX_DEPTH=3
MAX_CONCURRENT_REQUESTS=10
CRAWL_DELAY_MIN=2
CRAWL_DELAY_MAX=8
REQUEST_TIMEOUT=30
ROTATE_CIRCUIT_EVERY=50
MAX_PAGES_PER_DOMAIN=100
STAY_ON_DOMAIN=false

# ── Database ─────────────────────────────────────────────────
# Auto-generated by deploy.sh
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://scanner:changeme@postgres:5432/darkweb_scanner

# ── Dashboard ────────────────────────────────────────────────
DASHBOARD_PORT=8080
# REQUIRED: must be a long random string (min 32 chars). The app refuses to start
# if this is empty or set to a placeholder value. Generate with:
#   openssl rand -hex 32
DASHBOARD_SECRET_KEY=change-me-to-a-long-random-string

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
# Set to true to enable Flask debug mode (do not use in production)
FLASK_DEBUG=false

# ── SSL / Domain (Nginx) ──────────────────────────────────────────────────────
# Leave DOMAIN blank to use self-signed SSL (good for local/LAN use)
# Set DOMAIN to your public domain to get a free Let's Encrypt certificate
DOMAIN=
# Required if DOMAIN is set — used for Let's Encrypt certificate registration
SSL_EMAIL=
# Optional: www subdomain (if different from DOMAIN)
WWW_DOMAIN=

# ── Alerting: Webhook (Slack / Discord) ──────────────────────
# Leave blank to disable
ALERT_WEBHOOK_URL=

# ── Alerting: Email ──────────────────────────────────────────
# Leave blank to disable
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# ── Daily Digest (Mailgun) ────────────────────────────────────
# Free tier: 1 000 emails/month at mailgun.com
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
# Sender address shown in digest emails
MAILGUN_FROM=OSINT PH Threat Intel <digest@intel.osintph.info>

# ── Threat Intelligence Feeds ─────────────────────────────────
# AlienVault OTX — free at otx.alienvault.com
OTX_API_KEY=

# ransomware.live PRO — free at my.ransomware.live (3 000 calls/day)
RANSOMWARE_LIVE_API_KEY=

# ThreatFox (abuse.ch) — free at threatfox.abuse.ch
THREATFOX_API_KEY=

# WhiteIntel — free tier at whiteintel.io (credential exposure monitoring)
WHITEINTEL_API_KEY=

# DNSDumpster — for DNS investigation enrichment
DNSDUMPSTER_API_KEY=

# ── IP Investigation ──────────────────────────────────────────
# AbuseIPDB — free at https://www.abuseipdb.com/account/api (1 000 checks/day)
ABUSEIPDB_API_KEY=

# VirusTotal — free at https://www.virustotal.com/gui/my-apikey (4 req/min)
VIRUSTOTAL_API_KEY=

# HIBP — have-i-been-pwned.com API key ($3.50/month at haveibeenpwned.com/API/Key)
HIBP_API_KEY=

# ── Telegram Scraper (optional) ───────────────────────────────────────────────
# Get API credentials at: https://my.telegram.org/apps
# Run 'make telegram-auth' once to authenticate before scanning
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Required for Channel Monitor tab — your Telegram phone number (with country code)
TELEGRAM_PHONE=+1234567890
# Comma-separated list of public channel usernames (without @)
TELEGRAM_CHANNELS=channelname1,channelname2
TELEGRAM_SESSION_PATH=/app/data/telegram.session
TELEGRAM_LIMIT_PER_CHANNEL=200

# ── Quick Scan ────────────────────────────────────────────────
# Max concurrent source checks per Quick Scan session
QUICK_SCAN_MAX_CONCURRENT=4
# Delay range between source requests (seconds). Falls back to CRAWL_DELAY_* if unset.
QUICK_SCAN_DELAY_MIN=2
QUICK_SCAN_DELAY_MAX=8

# ── OAuth — Google (optional) ─────────────────────────────────────────────────
# Get credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://yourdomain.com/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OAuth — GitHub (optional) ─────────────────────────────────────────────────
# Get credentials at: https://github.com/settings/applications/new
# Authorization callback URL: https://yourdomain.com/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── OAuth — Microsoft (optional) ──────────────────────────────────────────────
# Get credentials at: https://portal.azure.com — App registrations
# Redirect URI: https://yourdomain.com/oauth/microsoft/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# ── OAuth — Apple Sign In (optional) ──────────────────────────────────────────
# Get credentials at: https://developer.apple.com/account/resources/identifiers
# Redirect URI: https://yourdomain.com/oauth/apple/callback
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
